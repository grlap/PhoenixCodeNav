<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <!-- Darwin exposes /tmp and /var as symlinks. Use their physical location so
         index-authority tests still exercise the no-follow path contract. -->
    <EnvironmentVariables>
      <TMPDIR>/private/tmp</TMPDIR>
    </EnvironmentVariables>

    <!-- These contracts require Windows path folding, .NET Framework reference
         assemblies, or Git review/worktree support that Phoenix does not expose
         on macOS. Keep the remaining cross-platform coverage enabled. -->
    <TestCaseFilter>
      FullyQualifiedName!~CodeNav.Tests.Batch42&amp;
      FullyQualifiedName!~CodeNav.Tests.Batch43&amp;
      FullyQualifiedName!~CodeNav.Tests.Batch44&amp;
      FullyQualifiedName!=CodeNav.Tests.Batch41Tests.UnixNormalIndexAuthorityRejectsDanglingParentAndDatabaseLinks&amp;
      FullyQualifiedName!=CodeNav.Tests.Batch25GitRobustnessTests.FirstCommitOnACommitlessRepoAdvancesTheIndex&amp;
      FullyQualifiedName!=CodeNav.Tests.Batch52TelemetryProducerTests.IdentityDerivationIsSaltScopedAndPathCaseInsensitive&amp;
      FullyQualifiedName!=CodeNav.Tests.Batch2SemanticTests.SkipWhenNoFrameworkRefs&amp;
      FullyQualifiedName!=CodeNav.Tests.Batch47GenericArityTests.ExplicitArityKeepsImplementationAndHierarchyFamiliesDisjoint&amp;
      FullyQualifiedName!=CodeNav.Tests.Batch47GenericArityTests.SearchSymbolArityAndHandlePinTheSameGenericFamily&amp;
      FullyQualifiedName!=CodeNav.Tests.InternalsVisibleToSemanticTests.LiteralFriendAssemblyControlsExactSubtypeVerification&amp;
      FullyQualifiedName!=CodeNav.Tests.Batch40Tests.SkippedFilesAndFailedProjectsAreCounted&amp;
      FullyQualifiedName!=CodeNav.Tests.Batch55TelemetryBuildFramesTests.StartupBuildAndRefreshEmitLifecycleFrames&amp;
      FullyQualifiedName!=CodeNav.Tests.WorkspacePathsTests.RejectsEscapingOrRootedPaths&amp;
      FullyQualifiedName!=CodeNav.Tests.FSharpTierATests.ReviewPackReportsFSharpChangesAtFileGranularity&amp;
      FullyQualifiedName!=CodeNav.Tests.FSharpSemanticStage2Tests.CaseSensitiveHostsPreserveDistinctCaseOnlySourcePaths&amp;
      FullyQualifiedName!=CodeNav.Tests.FSharpSemanticStage2Tests.LegacyImportedPropsAndChooseReachSemanticResolution&amp;
      FullyQualifiedName!=CodeNav.Tests.FSharpSemanticStage2Tests.PairedMigrationProjectsRequireAnExplicitPhysicalTypeCheckContext&amp;
      FullyQualifiedName!=CodeNav.Tests.FSharpSemanticStage2Tests.CancelledHintPathCaptureRemovesPartialSnapshot&amp;
      FullyQualifiedName!=CodeNav.Tests.FSharpSemanticStage2Tests.SemanticReferenceByteLimitRejectsBeforeCopyWithSpecificCause&amp;
      FullyQualifiedName!=CodeNav.Tests.FSharpSemanticStage2Tests.HintPathMustBeAManagedBoundedStableWorkspaceBinary&amp;
      FullyQualifiedName!=CodeNav.Tests.Batch1ToolTests.SourceContextRejectsWorkspaceEscape&amp;
      FullyQualifiedName!=CodeNav.Tests.SemanticTests.FrameworkReferenceAssembliesAreFound
    </TestCaseFilter>
  </RunConfiguration>
</RunSettings>
