    <PackageReference Include="System.IO.Hashing" Version="10.0.10" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\CodeNav.FSharp\CodeNav.FSharp.fsproj" />
  </ItemGroup>

