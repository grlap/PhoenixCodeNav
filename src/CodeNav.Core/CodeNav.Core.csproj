<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="CodeNav.Tests" />
    <InternalsVisibleTo Include="CodeNav.IndexTests" />
    <InternalsVisibleTo Include="CodeNav.GitTests" />
    <InternalsVisibleTo Include="CodeNav.WatcherTests" />
    <InternalsVisibleTo Include="CodeNav.LifecycleTests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.6.0" />
